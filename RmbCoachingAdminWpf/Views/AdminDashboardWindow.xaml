<Window x:Class="RmbCoachingAdminWpf.Views.AdminDashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RMB Coaching Admin"
        Height="720"
        Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Margin="20,20,20,12" CornerRadius="20" Background="White" Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="RMB Coaching Admin" FontSize="28" FontWeight="Bold" />
                    <TextBlock x:Name="WelcomeTextBlock" Margin="0,6,0,0" Foreground="#475569" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Frissítés" Width="110" Click="RefreshButton_Click" />
                    <Button Content="Új kurzus" Width="110" Click="AddButton_Click" />
                    <Button Content="Kijelentkezés" Width="110" Background="#64748B" Click="LogoutButton_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="20,0,20,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock x:Name="MessageTextBlock" Margin="0,0,0,10" Foreground="#0F172A" FontWeight="SemiBold" />

            <Border Grid.Row="1" Background="White" CornerRadius="20" Padding="14">
                <DataGrid x:Name="CoursesDataGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          RowBackground="White"
                          AlternatingRowBackground="#F8FAFC"
                          SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60" />
                        <DataGridTextColumn Header="Cím" Binding="{Binding Title}" Width="220" />
                        <DataGridTextColumn Header="Rövid leírás" Binding="{Binding ShortDescription}" Width="250" />
                        <DataGridTextColumn Header="Ár" Binding="{Binding Price}" Width="90" />
                        <DataGridTextColumn Header="Nap" Binding="{Binding DurationInDays}" Width="70" />
                        <DataGridTextColumn Header="Kategória" Binding="{Binding Category}" Width="130" />
                        <DataGridTextColumn Header="Nehézség" Binding="{Binding DifficultyLevel}" Width="110" />
                        <DataGridCheckBoxColumn Header="Előfizetés" Binding="{Binding IsSubscription}" Width="95" />
                        <DataGridCheckBoxColumn Header="Aktív" Binding="{Binding IsActive}" Width="80" />
                        <DataGridTemplateColumn Header="Műveletek" Width="170">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Szerkesztés"
                                                Padding="10,6"
                                                Margin="0,0,8,0"
                                                Click="EditButton_Click"
                                                Tag="{Binding}" />
                                        <Button Content="Törlés"
                                                Padding="10,6"
                                                Background="#DC2626"
                                                Click="DeleteButton_Click"
                                                Tag="{Binding}" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</Window>
