<Window x:Class="RmbCoachingAdminWpf.Views.CourseEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kurzus szerkesztése"
        Height="760"
        Width="650"
        WindowStartupLocation="CenterOwner"
        Background="#F8FAFC"
        ResizeMode="NoResize">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Border Background="White" CornerRadius="20" Padding="24">
                <StackPanel>
                    <TextBlock x:Name="HeaderTextBlock" FontSize="28" FontWeight="Bold" />
                    <TextBlock Text="Töltsd ki a mezőket a backend DTO szerint." Margin="0,8,0,24" Foreground="#475569" />

                    <TextBlock Text="Cím" FontWeight="SemiBold" />
                    <TextBox x:Name="TitleTextBox" />

                    <TextBlock Text="Rövid leírás" FontWeight="SemiBold" />
                    <TextBox x:Name="ShortDescriptionTextBox" />

                    <TextBlock Text="Teljes leírás" FontWeight="SemiBold" />
                    <TextBox x:Name="DescriptionTextBox" Height="130" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Ár" FontWeight="SemiBold" />
                            <TextBox x:Name="PriceTextBox" Margin="0,6,0,0" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Időtartam (nap)" FontWeight="SemiBold" />
                            <TextBox x:Name="DurationTextBox" Margin="0,6,0,0" />
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Kategória" FontWeight="SemiBold" />
                            <TextBox x:Name="CategoryTextBox" Margin="0,6,0,0" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Nehézség" FontWeight="SemiBold" />
                            <TextBox x:Name="DifficultyTextBox" Margin="0,6,0,0" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Kép URL" FontWeight="SemiBold" />
                    <TextBox x:Name="ImageUrlTextBox" />

                    <CheckBox x:Name="IsSubscriptionCheckBox" Content="Előfizetéses kurzus" Margin="0,4,0,10" />
                    <CheckBox x:Name="IsActiveCheckBox" Content="Aktív kurzus" Margin="0,0,0,16" IsChecked="True" />

                    <TextBlock x:Name="ValidationTextBlock" Foreground="#DC2626" Margin="0,0,0,12" TextWrapping="Wrap" />

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Mentés" Width="110" Click="SaveButton_Click" />
                        <Button Content="Mégse" Width="110" Background="#64748B" Click="CancelButton_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Window>
