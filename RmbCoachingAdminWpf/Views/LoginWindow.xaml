<Window x:Class="RmbCoachingAdminWpf.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RMB Coaching Admin - Bejelentkezés"
        Height="540"
        Width="920"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#EFF6FF">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.25*" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Margin="24" CornerRadius="24">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#1D4ED8" Offset="0" />
                    <GradientStop Color="#60A5FA" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid Margin="40">
                <Border Background="#1E3A8A" Opacity="1" CornerRadius="20" Padding="16" Margin="0,28,0,0">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="🏋" FontSize="78" HorizontalAlignment="Center" />
                        <TextBlock Text="RMB Admin" FontSize="34" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" />
                        
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="White" CornerRadius="24" Margin="0,24,24,24" Padding="32">
            <Grid>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Admin bejelentkezés" FontSize="28" FontWeight="Bold" />
                    <TextBlock Text="Ez a szerkeztő felület csak admin profillal hasznalható."
                               Margin="0,8,0,24"
                               TextWrapping="Wrap"
                               Foreground="#475569" />

                    <TextBlock Text="Email" FontWeight="SemiBold" />
                    <TextBox x:Name="EmailTextBox" />

                    <TextBlock Text="Jelszó" FontWeight="SemiBold" />
                    <PasswordBox x:Name="PasswordBox" />

                    <TextBlock x:Name="StatusTextBlock"
                               Foreground="#DC2626"
                               Margin="0,4,0,12"
                               TextWrapping="Wrap" />

                    <Button x:Name="LoginButton"
                            Content="Belépés"
                            Height="44"
                            Click="LoginButton_Click" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
